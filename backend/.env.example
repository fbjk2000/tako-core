MONGO_URL="mongodb://mongo:27017"
DB_NAME="test_database"

JWT_SECRET="change-me-before-public-exposure"
JWT_ALGORITHM="HS256"
# Legacy single-token expiry — still honoured for pre-refactor sessions.
JWT_EXPIRY_HOURS=168
# New dual-token flow (FOLLOWUPS #9): short-lived access token + long-lived
# refresh token. Change these only if you understand the rotation semantics
# in backend/server.py::_issue_token_pair.
JWT_ACCESS_EXPIRY_MINUTES=15
JWT_REFRESH_EXPIRY_DAYS=7

FRONTEND_URL="http://localhost:3000"
PUBLIC_URL="http://localhost:3000"

SUPER_ADMIN_EMAIL="admin@example.com"

# Your company VAT number — shown on every invoice. Required on HMRC- and
# EU-compliant invoices; leaving this blank keeps the obvious placeholder
# `GB000000000` so nothing silently ships without one.
COMPANY_VAT_NUMBER="GB000000000"

# Optional integrations (set when needed)
STRIPE_API_KEY=""
STRIPE_WEBHOOK_SECRET=""

# ── Stripe Price IDs for the three self-hosted licence plans ──
# Create these in the Stripe dashboard as Products with Prices:
#   - STRIPE_PRICE_ONETIME:     one-time payment, EUR 5,000
#   - STRIPE_PRICE_12MO:        recurring monthly, EUR 500/month
#   - STRIPE_PRICE_24MO:        recurring monthly, EUR 300/month
#   - STRIPE_PRICE_MAINTENANCE: one-time payment, EUR 999 (annual renewal)
# Installment plans (12mo/24mo) require the recurring Price IDs to be set —
# checkout will 500 without them. STRIPE_PRICE_ONETIME is optional; if blank
# the one-time plan falls back to an inline price_data session.
STRIPE_PRICE_ONETIME=""
STRIPE_PRICE_12MO=""
STRIPE_PRICE_24MO=""
STRIPE_PRICE_MAINTENANCE=""

# AI — platform key used for trial users and paid licence holders. Customers
# can also bring their own key via Settings → Integrations (BYOK), in which
# case this is not needed for them.
ANTHROPIC_API_KEY=""

# Other optional integrations
EMERGENT_LLM_KEY=""
RESEND_API_KEY=""
SENDER_EMAIL="noreply@example.com"
KIT_API_KEY=""
KIT_API_SECRET=""
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_FROM=""
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

