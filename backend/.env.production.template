# TAKO Backend — Production Environment
# Copy to .env and fill in all values before deploying.
# Lines marked [REQUIRED] must be set. Lines marked [OPTIONAL] can wait.

# === DATABASE ===
MONGO_URL="mongodb://mongo:27017"          # [REQUIRED] Internal Docker network address
DB_NAME="tako_production"                   # [REQUIRED] Change from test_database

# === AUTH ===
JWT_SECRET=""                               # [REQUIRED] Generate: openssl rand -hex 32
JWT_ALGORITHM="HS256"                       # [REQUIRED] Keep as-is
JWT_EXPIRY_HOURS=168                        # [REQUIRED] 7 days

# === URLS ===
FRONTEND_URL=""                             # [REQUIRED] e.g. https://app.tako.software
PUBLIC_URL=""                               # [REQUIRED] Same as FRONTEND_URL

# === ADMIN ===
SUPER_ADMIN_EMAIL="florian@unyted.world"   # [REQUIRED]

# === EMAIL (Resend) ===
RESEND_API_KEY=""                           # [OPTIONAL] From https://resend.com/api-keys
SENDER_EMAIL="noreply@tako.software"        # [OPTIONAL] Needs domain verification in Resend

# === PAYMENTS (Stripe) ===
STRIPE_API_KEY=""                           # [OPTIONAL] From https://dashboard.stripe.com/apikeys
STRIPE_WEBHOOK_SECRET=""                    # [OPTIONAL] From Stripe webhook config

# === CALLING (Twilio) ===
TWILIO_ACCOUNT_SID=""                       # [OPTIONAL] From https://console.twilio.com
TWILIO_AUTH_TOKEN=""                        # [OPTIONAL] From Twilio console
TWILIO_PHONE_FROM=""                        # [OPTIONAL] Your Twilio phone number

# === GOOGLE (Calendar sync) ===
GOOGLE_CLIENT_ID=""                         # [OPTIONAL] From Google Cloud Console
GOOGLE_CLIENT_SECRET=""                     # [OPTIONAL] From Google Cloud Console

# === AI / OTHER ===
EMERGENT_LLM_KEY=""                         # [OPTIONAL] LLM API key
KIT_API_KEY=""                              # [OPTIONAL] Kit integration
KIT_API_SECRET=""                           # [OPTIONAL] Kit integration
