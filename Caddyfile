# TAKO Production Caddyfile
# Caddy automatically provisions and renews Let's Encrypt SSL certificates.
# DNS A record for tako.software must point to this server's IP.

tako.software {
    # Backend API — match /api/* and proxy with path preserved
    handle /api/* {
        reverse_proxy backend:8001
    }

    # Twilio webhooks — must be accessible
    handle /webhooks/* {
        reverse_proxy backend:8001
    }

    # Frontend — everything else
    handle {
        reverse_proxy frontend:3000
    }
}

# Temporary bridge: redirect old domain to new
clients.earnrm.com {
    redir https://tako.software{uri} permanent
}
